---
import Layout from '@/layouts/Layout.astro'
import { getCollection, render, type CollectionEntry } from 'astro:content'

export async function getStaticPaths() {
  let entries: CollectionEntry<'state-manager'>[] = await getCollection('state-manager')

  return entries.map((entry: CollectionEntry<'state-manager'>) => ({ params: { slug: entry.id }, props: { entry } }))
}

const { entry } = Astro.props
const { Content, headings, remarkPluginFrontmatter } = await render(entry)
---

<Layout frontmatter={{ ...remarkPluginFrontmatter, url: entry.id }} headings={headings}>
  <Content />
</Layout>
